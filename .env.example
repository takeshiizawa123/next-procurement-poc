# ============================================================
# 購買管理システム 環境変数テンプレート
# ============================================================
# このファイルを .env.local にコピーして値を設定してください。
# cp .env.example .env.local
#
# Vercel環境では Vercel Dashboard > Settings > Environment Variables で設定。
# ============================================================

# --- データストア (Supabase Postgres, Tokyo) ---
# Vercel Marketplace → Supabase で自動設定される
POSTGRES_URL=postgres://user:pass@host:5432/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:pass@host:5432/dbname?sslmode=require

# --- キャッシュ (Upstash Redis, Tokyo) ---
# Vercel Marketplace → Upstash で自動設定される
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx

# --- 認証 (NextAuth v5 + Google OAuth) ---
AUTH_SECRET=  # openssl rand -base64 32 で生成
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_ALLOWED_DOMAIN=futurestandard.co.jp  # オプション: ドメイン制限

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=xxx
SLACK_PURCHASE_CHANNEL=Cxxxxxxxxxx  # #purchase-request のチャンネルID
SLACK_OPS_CHANNEL=Cxxxxxxxxxx       # #purchase-ops のチャンネルID
SLACK_TRIP_CHANNEL=Cxxxxxxxxxx      # #出張 のチャンネルID
SLACK_DEFAULT_APPROVER=Uxxxxxxxxxx  # デフォルト承認者のSlack User ID
SLACK_ADMIN_APPROVER=Uxxxxxxxxxx    # 管理本部承認者のSlack User ID
SLACK_ADMIN_MEMBERS=Uxx,Uxx,Uxx    # 管理本部メンバーのSlack User ID（カンマ区切り）

# --- API認証 ---
CRON_SECRET=xxx          # Cron認証用（任意の安全な文字列）
INTERNAL_API_KEY=xxx     # ブラウザ→API認証（任意の安全な文字列）
NEXT_PUBLIC_INTERNAL_API_KEY=xxx  # 上記と同じ値（クライアント側用）

# --- MF会計Plus (OAuth 2.0) ---
MF_CLIENT_ID=xxx
MF_CLIENT_SECRET=xxx
MF_REDIRECT_URI=https://your-domain.vercel.app/api/mf/callback

# --- MF経費 ---
MF_EXPENSE_ACCESS_TOKEN=xxx
MF_EXPENSE_OFFICE_ID=xxx

# --- AI / OCR ---
GEMINI_API_KEY=xxx              # Gemini Vision API（証憑OCR）
ANTHROPIC_API_KEY=xxx           # Claude Haiku（Slack AIアシスタント /ask）

# --- Google Drive (証憑保存 + バックアップ) ---
GOOGLE_SERVICE_ACCOUNT_KEY=xxx  # Base64エンコードしたJSON鍵
GOOGLE_DRIVE_ROOT_FOLDER_ID=xxx # 証憑保存先フォルダID
GOOGLE_DRIVE_BACKUP_FOLDER_ID=xxx  # DBバックアップ保存先フォルダID

# --- オプション ---
TEST_MODE=false                 # true: 全DMをテストチャンネルにリダイレクト
BACKUP_RETENTION_DAYS=0         # 0: 永久保持、N: N日後に削除

# --- 非推奨（DB移行後は不要）---
# GAS_WEB_APP_URL=https://script.google.com/macros/s/xxx/exec
# GAS_API_KEY=xxx
