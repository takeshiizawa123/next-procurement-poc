// --- マスタ一括取得 ---

export interface MastersBundle {
  accounts: GasAccount[];
  taxes: GasTax[];
  departments: GasDepartment[];
  subAccounts: GasSubAccount[];
  projects: GasProject[];
  counterparties: GasCounterparty[];
}

/**
 * 全マスタを1回のGAS呼び出しで一括取得（6往復→1往復、4時間キャッシュ + リクエスト合体）
 */
export async function getMastersBundle(): Promise<GasResponse<MastersBundle>> {
  return cachedFetch("gasMastersBundle", GAS_MASTER_TTL, async () => {
    const result = await callGasGet<MastersBundle>({ action: "getMastersBundle" });
    if (result.success && result.data) {
      // 個別キャッシュにも書き込み（他の関数がキャッシュヒットできるように）
      await Promise.all([
        sharedCacheSet("gasMfAccounts", { success: true, data: { accounts: result.data.accounts } }, GAS_MASTER_TTL),
        sharedCacheSet("gasMfTaxes", { success: true, data: { taxes: result.data.taxes } }, GAS_MASTER_TTL),
        sharedCacheSet("gasMfDepartments", { success: true, data: { departments: result.data.departments } }, GAS_MASTER_TTL),
        sharedCacheSet("gasMfSubAccounts", { success: true, data: { subAccounts: result.data.subAccounts } }, GAS_MASTER_TTL),
        sharedCacheSet("gasMfProjects", { success: true, data: { projects: result.data.projects } }, GAS_MASTER_TTL),
        sharedCacheSet("gasMfCounterparties", { success: true, data: { counterparties: result.data.counterparties } }, GAS_MASTER_TTL),
      ]);
    }
    return result;
  });
}

// --- 過去仕訳統計 ---

export interface CounterpartyAccountStat {
  counterparty: string;
  account: string;
  taxType: string;
  count: number;
}

export interface DeptAccountTaxStat {
  department: string;
  account: string;
  taxType: string;
  count: number;
}

export interface RemarkAccountStat {
  keyword: string;
  account: string;
  taxType: string;
  count: number;
}

export interface JournalStats {
  counterpartyAccounts: CounterpartyAccountStat[];
  deptAccountTax: DeptAccountTaxStat[];
  remarkAccounts: RemarkAccountStat[];
  totalJournals: number;
  totalRows: number;
  computedAt: string;
}

const STATS_CACHE_TTL = 60 * 60 * 1000; // 1時間

/**
 * 過去仕訳統計をGASから取得（1時間キャッシュ + リクエスト合体）
 */
export async function getJournalStats(): Promise<JournalStats | null> {
  try {
    const result = await cachedFetch("journalStats", STATS_CACHE_TTL, () =>
      callGasGet<{ stats: JournalStats }>({ action: "getJournalStats" }),
    );
    return result.success && result.data?.stats ? result.data.stats : null;
  } catch (e) {
    console.warn("[gas-client] Failed to fetch journal stats:", e);
    return null;
  }
}

// --- 過去仕訳 原票検索 ---

export interface JournalRow {
  date: string;
  remark: string;
  account: string;
  taxType: string;
  amount: number;
  department: string;
  counterparty: string;
}

export interface JournalRowsResult {
  supplierMatches: JournalRow[];
  keywordMatches: JournalRow[];
}

/**
 * 過去仕訳の原票を取引先・品名キーワードで検索
 * キャッシュなし（検索条件が毎回異なるため）
 */
export async function searchJournalRows(
  supplier: string,
  keyword: string,
): Promise<JournalRowsResult | null> {
  try {
    const result = await callGasGet<JournalRowsResult>({
      action: "searchJournalRows",
      supplier,
      keyword,
    });
    if (result.success && result.data) {
      return result.data;
    }
  } catch (e) {
    console.warn("[gas-client] Failed to search journal rows:", e);
  }
  return null;
}

// --- MF APIマスタのJSONキャッシュ（勘定科目・税区分・PJ・補助科目） ---

export interface MfMastersCache {
  accounts: { code: string | null; name: string; taxId?: number }[];
  taxes: { code: string | null; name: string; abbreviation?: string; taxRate?: number }[];
  subAccounts: { id: number; accountId: number; name: string }[];
  projects: { code: string | null; name: string }[];
  syncedAt: string;
}

/**
 * MF APIマスタ（科目・税区分・PJ・補助科目）をGASに保存
 */
export async function saveMfMasters(masters: MfMastersCache): Promise<GasResponse<{ saved: boolean }>> {
  return callGasPost<{ saved: boolean }>("saveMfMasters", { masters });
}

/**
 * GASからMF APIマスタキャッシュを取得
 */
export async function getMfMasters(): Promise<GasResponse<{ masters: MfMastersCache }>> {
  return callGasGet<{ masters: MfMastersCache }>({ action: "getMfMasters" });
}

// --- 購買申請 下書き保存（GASスプレッドシート、1か月自動消去） ---

/**
 * ��書きを保存（GAS側で userId + JSON + savedAt を保存）
 * GAS側は1か月以上前の下書きを自動削除する
 */
export async function savePurchaseDraft(
  userId: string,
  data: Record<string, unknown>,
): Promise<void> {
  try {
    await callGasPost("saveDraft", { userId, draft: data });
  } catch (e) {
    console.warn("[gas-client] Failed to save draft:", e);
  }
}

/**
 * 下書きを読み込み（直近1件のみ）
 */
export async function loadPurchaseDraft(
  userId: string,
): Promise<Record<string, unknown> | null> {
  try {
    const result = await callGasGet<{ draft: Record<string, unknown> | null }>({
      action: "loadDraft",
      userId,
    });
    if (result.success && result.data?.draft) {
      return result.data.draft;
    }
  } catch (e) {
    console.warn("[gas-client] Failed to load draft:", e);
  }
  return null;
}

/**
 * 下書きを削除（申請成功時に呼ぶ）
 */
export async function clearPurchaseDraft(userId: string): Promise<void> {
  try {
    await callGasPost("clearDraft", { userId });
  } catch (e) {
    console.warn("[gas-client] Failed to clear draft:", e);
  }
}
